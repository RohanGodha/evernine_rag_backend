# --- LLM (Groq) ---
# Scoped key handed to you on the day. Never commit the real value.
GROQ_API_KEY=your_scoped_key_here
# Groq is OpenAI-compatible. gpt-oss-20b supports strict structured output.
GROQ_MODEL=openai/gpt-oss-20b
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Max retries for transient LLM failures before falling back.
LLM_MAX_RETRIES=2

# --- Database (Postgres) ---
# Matches docker-compose.yml. Override for a hosted instance (Neon/Supabase).
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/aster_oak

# --- Optional vector RAG (OFF by default) ---
# This task is enrichment over self-contained rows, not Q&A over external
# knowledge, so RAG adds latency + heavy deps with no quality gain. Leave false.
# If set true, also: pip install -r requirements-rag.txt
RAG_ENABLED=false
